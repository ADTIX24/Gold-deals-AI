{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with credits and role",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "credits": { "type": "number", "description": "User's current credit balance" },
        "isAdmin": { "type": "boolean" },
        "unlockedSignals": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "email", "credits"]
    },
    "AppConfig": {
      "title": "General Settings",
      "description": "Application wide settings managed by admin",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string" },
        "telegramUrl": { "type": "string" },
        "instagramUrl": { "type": "string" },
        "snapchatUrl": { "type": "string" },
        "tiktokUrl": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "whatsappUrl": { "type": "string" },
        "facebookUrl": { "type": "string" },
        "supportUrl": { "type": "string", "description": "Technical support link (usually Telegram)" },
        "supportMessage": { "type": "string", "description": "Support information text shown in the wallet view" },
        "supportUrl2": { "type": "string" },
        "showSupport2": { "type": "boolean" },
        "marketSentiment": { "type": "string", "enum": ["safe", "tense", "dangerous"], "description": "Current market sentiment state" },
        "announcement": { "type": "string" },
        "footerCopyright": { "type": "string" },
        "marketStatus": { "type": "string", "enum": ["active", "closed"], "description": "Global market status text" },
        "marketAnalysis": { "type": "string", "description": "Admin's market analysis text" },
        "weeklyNews": { "type": "string", "description": "Admin's weekly news text" },
        "footerLinks": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "labelEn": { "type": "string" },
              "labelAr": { "type": "string" },
              "url": { "type": "string" },
              "contentEn": { "type": "string" },
              "contentAr": { "type": "string" }
            }
          }
        }
      }
    },
    "AIHistory": {
      "title": "AI Signal History",
      "description": "History of signals generated by the AI for a specific user",
      "type": "object",
      "properties": {
        "pair": { "type": "string" },
        "type": { "type": "string", "enum": ["buy", "sell"] },
        "category": { "type": "string", "enum": ["scalping", "swing"] },
        "entry": { "type": "number" },
        "tp": { "type": "number" },
        "sl": { "type": "number" },
        "analysis": { "type": "string" },
        "strategyUsed": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["pair", "type", "entry", "tp", "sl", "timestamp"]
    },
    "Signal": {
      "title": "Public Signal",
      "description": "A trading signal posted by an admin",
      "type": "object",
      "properties": {
        "pair": { "type": "string" },
        "type": { "type": "string", "enum": ["buy", "sell"] },
        "category": { "type": "string", "enum": ["scalping", "swing"] },
        "entry": { "type": "number" },
        "tp": { "type": "number" },
        "sl": { "type": "number" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["pair", "type", "entry", "tp", "sl", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/users/{userId}/ai_history/{historyId}": {
      "schema": "AIHistory",
      "description": "History of AI generations for this user"
    },
    "/settings/general": {
      "schema": "AppConfig",
      "description": "Universal app configuration"
    },
    "/signals/{signalId}": {
      "schema": "Signal",
      "description": "Public trading signals"
    }
  }
}
